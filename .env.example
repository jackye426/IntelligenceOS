# Copy this to .env.local for local development and fill with non-production values.
# Do not commit real secrets.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_PRACTITIONERS_TABLE=integrated_practitioner_with_phin
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_JUDGE_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
MODEL_OCR=google/gemini-3-flash-preview
# Video component cards (text over transcript/hooks) — cheap chat model; OCR stays on MODEL_OCR
MODEL_COMPONENTS=deepseek/deepseek-v4-flash
# Alternative if flash quality is weak: deepseek/deepseek-v4-pro

SESSION_PASSWORD=
INTERNAL_PASSWORD=

MCP_AUTH_TOKEN=
MCP_ALLOWED_ORIGINS=
MCP_ALLOWED_HOSTS=
MCP_DNS_REBINDING_PROTECTION=true
MCP_MAX_SENSITIVITY=confidential
MCP_HOST=0.0.0.0
MCP_PORT=8000

# data-worker production (Railway)
SKIP_CONTENT_TRACKER=true
SKIP_HCA=true

# TikTok Display API (Login Kit) — velocity snapshots every ~3h
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
# Optional override for Business Center CSV drop zone
# TIKTOK_BC_IMPORTS_DIR=

# Studio Playwright (production: Tue/Fri, newest 15). Full baseline is manual --all.
# SKIP_STUDIO_LISTEN=true
# STUDIO_LISTEN_RECENT=15
# STUDIO_LISTEN_SETTLE_MS=5000
# STUDIO_LISTEN_PAUSE_MS=10000
# STUDIO_LISTEN_PAUSE_JITTER_MS=4000
# STUDIO_LISTEN_BASELINE_PAUSE_MS=8000

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

RELATIONSHIP_GMAIL_CLIENT_ID=
RELATIONSHIP_GMAIL_CLIENT_SECRET=
RELATIONSHIP_GMAIL_REFRESH_TOKEN=
RELATIONSHIP_GMAIL_ACCOUNT_EMAIL=admin@docmap.co.uk
RELATIONSHIP_GMAIL_SEND_AS_ALIASES=admin@docmap.co.uk,jack@docmap.co.uk,kevin@docmap.co.uk,hello@docmap.co.uk
RELATIONSHIP_GMAIL_DEFAULT_SEND_AS=admin@docmap.co.uk

# ingestion-pipeline (defaults shown; all optional)
INGESTION_IMPORTS_DIR=data/imports
INGESTION_STAGING_DIR=data/staging
INGESTION_CLASSIFY_THRESHOLD=0.85
CLINIC_SALES_CSV_PATH=Clinic sales agent/output/clinic_sales_results.csv

# gtm-pipeline (optional)
# GTM_DATA_DIR=data/gtm
# CQC_DIRECTORY_PATH=Clinic sales agent/output/cqc_directory.csv
# CQC_API_KEY=
# GTM_MATCH_AUTO_ACCEPT=0.80
# GTM_MATCH_REVIEW_THRESHOLD=0.50
